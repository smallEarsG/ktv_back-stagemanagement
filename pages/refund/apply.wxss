page {
  background-color: #f7f8fa;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  height: 100%;
}

/* Common Card Style */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  width: 100%;
}

.card-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
}

/* Product List */
.product-list {
  display: flex;
  flex-direction: column;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s ease;
}

.product-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.product-item.selected {
  background-color: #fff9f9; /* Light red bg for selected */
  margin: 0 -32rpx; /* Extend to edges */
  padding: 24rpx 32rpx;
}

.checkbox-wrapper {
  margin-right: 24rpx;
  display: flex;
  align-items: center;
}

/* Transform checkbox to circle if needed, or stick to default color */
checkbox .wx-checkbox-input {
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
}

checkbox .wx-checkbox-input.wx-checkbox-input-checked {
  background: #d81e06;
  border-color: #d81e06;
}

.product-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-main {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.price {
  font-size: 28rpx;
  color: #d81e06;
  font-weight: bold;
}

.qty-label {
  font-size: 28rpx;
  color: #999;
}

/* Stepper */
.stepper {
  display: flex;
  align-items: center;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  padding: 4rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 36rpx;
  color: #333;
  font-weight: 300;
  background-color: #fff;
  border-radius: 6rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.stepper-btn.disabled {
  color: #ccc;
  background-color: #f7f8fa;
  box-shadow: none;
}

.stepper-num {
  width: 70rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* Form Items */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.vertical {
  flex-direction: column;
  align-items: flex-start;
  padding-top: 32rpx;
}

.form-item .label {
  font-size: 30rpx;
  color: #333;
  width: 160rpx;
}

.form-item.vertical .label {
  margin-bottom: 20rpx;
}

.picker-box {
  flex: 1;
  text-align: right;
}

.picker-inner {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 30rpx;
  color: #333;
}

.picker-inner .placeholder {
  color: #999;
}

.arrow-right {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #ccc;
  border-right: 2rpx solid #ccc;
  transform: rotate(45deg);
  margin-left: 12rpx;
}

/* Textarea Box */
.textarea-box {
  width: 100%;
  position: relative;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.reason-input {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.submit-btn {
  background: linear-gradient(90deg, #ff5e3a 0%, #d81e06 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height:2;
  box-shadow: 0 8rpx 16rpx rgba(216, 30, 6, 0.2);
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.99);
}