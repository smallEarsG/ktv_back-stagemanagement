<view class="container">
  <!-- Top Info -->
  <view class="header">
    <view class="store-name">{{storeInfo.storeName || '请扫码点单'}}</view>
    <view class="seat-info" wx:if="{{storeInfo.seatId}}">当前座位: {{storeInfo.seatId}}</view>
  </view>

  <!-- Main Content -->
  <view class="main-content">
    <!-- Left Category -->
    <scroll-view class="category-list" scroll-y="true">
      <view 
        wx:for="{{categories}}" 
        wx:key="id" 
        class="category-item {{currentCategoryIndex === index ? 'active' : ''}}"
        bindtap="switchCategory"
        data-index="{{index}}"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <!-- Right Product List -->
    <scroll-view class="product-list" scroll-y="true" scroll-into-view="{{toView}}" bindscroll="onProductScroll">
      <view class="product-section" wx:for="{{categories}}" wx:key="id" id="cat_{{index}}">
        <view class="section-title">{{item.name}}</view>
        <view 
          class="product-item" 
          wx:for="{{item.products}}" 
          wx:for-item="product" 
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{product.id}}"
        >
          <image class="product-img" src="{{product.image}}" mode="aspectFill"></image>
          <view class="product-info">
            <view class="product-name">{{product.name}}</view>
            <view class="product-price"><text class="price-symbol">¥</text>{{product.price}}</view>
            <view class="stepper">
              <view class="minus" catchtap="decreaseCart" data-item="{{product}}" wx:if="{{product.cartNum > 0}}">-</view>
              <view class="count" wx:if="{{product.cartNum > 0}}">{{product.cartNum}}</view>
              <view class="plus" catchtap="increaseCart" data-item="{{product}}">+</view>
            </view>
          </view>
        </view>
      </view>
      <!-- Spacer for bottom cart -->
      <view style="height: 120rpx;"></view>
    </scroll-view>
  </view>

  <!-- Bottom Cart Bar -->
  <view class="cart-bar" bindtap="toggleCartList">
    <view class="cart-icon-wrapper">
      <view class="cart-icon">🛒</view>
      <view class="badge" wx:if="{{totalNum > 0}}">{{totalNum}}</view>
    </view>
    <view class="cart-price">
      <view class="total-price"><text class="price-symbol">¥</text>{{totalPrice}}</view>
    </view>
    <view class="pay-btn {{totalNum > 0 ? 'active' : ''}}" catchtap="goToConfirm">
      选好了
    </view>
  </view>
</view>
