.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #fff;
}

.header {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
}

.store-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.seat-info {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.main-content {
  width: 100%;
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* Left Category */
.category-list {
  width: 180rpx;
  background-color: #f7f8fa;
  height: 100%;
}

.category-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.category-item.active {
  background-color: #fff;
  color: #333;
  font-weight: 600;
  font-size: 28rpx;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30rpx;
  bottom: 30rpx;
  width: 8rpx;
  background-color: #e02020;
  border-radius: 0 4rpx 4rpx 0;
}

/* Right Product List */
.product-list {
  flex: 1;
  background-color: #fff;
  height: 100%;
  padding: 0 24rpx;
}

.section-title {
  padding: 24rpx 0 16rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 1;
}

.product-item {
  display: flex;
  padding-bottom: 30rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.product-item:last-child {
  border-bottom: none;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.product-price {
  color: #e02020;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.stepper {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.minus, .plus {
  width: 50rpx;
  height: 50rpx;
  line-height: 46rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 36rpx;
  font-weight: bold;
  box-sizing: border-box;
}

.minus {
  border: 2rpx solid #ddd;
  color: #999;
  background: #fff;
}

.plus {
  background-color: #e02020;
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 10rpx rgba(224, 32, 32, 0.3);
}

.count {
  margin: 0 20rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* Bottom Cart Bar */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #333;
  display: flex;
  align-items: center;
  z-index: 999;
  /* padding-bottom: env(safe-area-inset-bottom); */
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.cart-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-left: 30rpx;
  margin-top: -30rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 -4rpx 10rpx rgba(0,0,0,0.1);
}

.cart-icon {
  font-size: 56rpx;
}

.badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #e02020;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
}

.cart-price {
  flex: 1;
  margin-left: 30rpx;
  color: #fff;
  display: flex;
  align-items: baseline;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.total-price .price-symbol {
  font-size: 28rpx;
}

.pay-btn {
  width: 220rpx;
  height: 100%;
  background-color: #444;
  color: #999;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.pay-btn.active {
  background: linear-gradient(135deg, #ff6034, #ee0a24);
  color: #fff;
  box-shadow: -4rpx 0 10rpx rgba(238, 10, 36, 0.2);
}
