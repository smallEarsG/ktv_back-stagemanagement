page {
  background-color: #f5f6fa;
  --primary-color: #e54d42;
  --text-main: #333333;
  --text-sub: #999999;
}

.container {
  min-height: 100vh;
  padding-bottom: 180rpx; /* 留出底部按钮空间 */
  box-sizing: border-box;
}

/* 顶部背景 */
.header-bg {
  background: linear-gradient(135deg, #ff5e57 0%, #ff3b30 100%);
  height: 360rpx;
  width: 100%;
  position: relative;
  z-index: 1;
}

.status-section {
  padding: 60rpx 40rpx;
  color: #fff;
}

.status-main {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.status-sub {
  font-size: 26rpx;
  opacity: 0.9;
  padding-left: 60rpx; /* 对齐文字 */
}

/* 内容区域 */
.content-wrapper {
  margin-top: -120rpx; /* 负 margin 上移 */
  padding: 0 24rpx;
  position: relative;
  z-index: 2;
  width: 100%;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  position: relative;
  padding-left: 20rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background-color: var(--primary-color);
  border-radius: 4rpx;
}

/* 订单信息列表 */
.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  color: var(--text-sub);
}

.info-item .value {
  color: var(--text-main);
  font-weight: 500;
}

.copy-row {
  display: flex;
  align-items: center;
}

.copy-btn {
  font-size: 20rpx;
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

/* 商品列表 */
.product-count {
  font-size: 24rpx;
  color: var(--text-sub);
}

.product-item {
  display: flex;
  margin-bottom: 32rpx;
}

.product-img-placeholder {
  width: 100rpx;
  height: 100rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.product-name {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.4;
  font-weight: 500;
}

.product-remark {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-top: 8rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  color: var(--text-main);
  font-weight: 600;
  font-size: 30rpx;
}

.product-qty {
  color: var(--text-sub);
  font-size: 26rpx;
}

/* 价格汇总 */
.price-summary {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eee;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.summary-row .label {
  color: var(--text-sub);
}

.summary-row .value {
  color: var(--text-main);
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.total-row .label {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
}

.price-box {
  color: var(--primary-color);
  display: flex;
  align-items: baseline;
}

.symbol {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.big-price {
  font-size: 52rpx;
  font-weight: bold;
  font-family: DINAlternate-Bold, "Helvetica Neue", Helvetica, sans-serif;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: flex-end;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.btn-secondary {
  margin: 0 20rpx 0 0;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  padding: 0 36rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-secondary::after {
  border: none;
}

.btn-primary {
  margin: 0;
  background: linear-gradient(135deg, #ff5e57 0%, #ff3b30 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 6rpx 12rpx rgba(255, 59, 48, 0.3);
}

.btn-primary::after {
  border: none;
}
