.container {
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  
}

.section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.store-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
}

.label {
  color: #666;
}

.value {
  font-weight: bold;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}

.order-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  background-color: #eee;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.item-remark {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.item-price {
  color: #d81e06;
  font-weight: bold;
}

.stepper {
  display: flex;
  align-items: center;
}

.minus, .plus {
  width: 50rpx;
  height: 50rpx;
  line-height: 46rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  border-radius: 50%;
  font-size: 36rpx;
  color: #666;
}

.count {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
}

.total-price {
  font-size: 32rpx;
}

.price-num {
  color: #d81e06;
  font-size: 40rpx;
  font-weight: bold;
}

.pay-btn {
  background-color: #d81e06;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
}
