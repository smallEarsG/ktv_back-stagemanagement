<view class="container">
  <view class="order-list">
    <view 
      class="order-item" 
      wx:for="{{orderList}}" 
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="item-header">
        <text class="store-name">KTV旗舰店 ({{item.seatId}})</text>
        <text class="status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      
      <view class="item-content">
        <image class="product-img" src="{{item.firstImage}}" mode="aspectFill"></image>
        <view class="info">
          <view class="order-no">订单号：{{item.orderNo}}</view>
          <view class="desc">共 {{item.totalCount}} 件商品</view>
        </view>
      </view>
      
      <view class="item-footer">
        <view class="time">{{item.createTime}}</view>
        <view class="action-area">
          <view class="price-container">
            <text class="price-symbol">¥</text>
            <text class="price">{{item.totalPrice}}</text>
          </view>
          <view class="btn-detail">查看详情</view>
        </view>
      </view>
    </view>
    
    <view class="empty" wx:if="{{orderList.length === 0}}">
      <text>暂无订单</text>
    </view>
  </view>
</view>