.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx 12rpx;
}
.order-list{
  width: 100%;
}
.order-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.store-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.status {
  font-size: 28rpx;
  font-weight: 500;
}

/* Delivering - Blue */
.status-2 {
  color: #1989fa;
}

/* Completed - Green */
.status-3 {
  color: #07c160;
}

.item-content {
  display: flex;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.product-img {
  width: 80rpx;
  height: 80rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info {
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  flex: 1;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.time {
  font-size: 22rpx;
  color: #ccc;
  margin-bottom: 6rpx;
}

.action-area {
  display: flex;
  align-items: center;
}

.price-container {
  display: flex;
  align-items: baseline;
  margin-right: 24rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.price {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-left: 2rpx;
}

.btn-detail {
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  line-height: 1;
}

.empty {
  text-align: center;
  margin-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}