<view class="container">
  <!-- 顶部背景与状态 -->
  <view class="header-bg">
    <view class="status-section">
      <view class="status-main">
        <text class="status-icon" wx:if="{{order.status === 1}}">🕒</text>
        <text class="status-icon" wx:elif="{{order.status === 2}}">✅</text>
        <text class="status-text">{{order.statusText}}</text>
      </view>
      <view class="status-sub">感谢您的光临，祝您生活愉快</view>
    </view>
  </view>

  <!-- 内容区域，通过负margin上移 -->
  <view class="content-wrapper">
    <!-- 订单信息卡片 -->
    <view class="card info-card">
      <view class="card-header">
        <text class="card-title">订单详情</text>
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="label">房间号</text>
          <text class="value">{{order.seatId}}</text>
        </view>
        <view class="info-item">
          <text class="label">下单时间</text>
          <text class="value">{{order.createTime}}</text>
        </view>
        <view class="info-item">
          <text class="label">订单编号</text>
          <text class="value copy-row">
            <text>{{order.orderNo || '202310270001'}}</text>
            <text class="copy-btn">复制</text>
          </text>
        </view>
      </view>
    </view>

    <!-- 商品明细卡片 -->
    <view class="card product-card">
      <view class="card-header">
        <text class="card-title">商品明细</text>
        <text class="product-count">共 {{order.products.length}} 件</text>
      </view>
      <view class="product-list">
        <view class="product-item" wx:for="{{order.products}}" wx:key="id">
          <!-- 模拟商品图片占位 -->
          <view class="product-img-placeholder">🍺</view>
          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-remark" wx:if="{{item.remark}}">备注: {{item.remark}}</view>
            <view class="product-meta">
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-qty">x{{item.count}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 价格小结 -->
      <view class="price-summary">
        <view class="summary-row">
          <text class="label">商品总额</text>
          <text class="value">¥{{order.totalPrice}}</text>
        </view>
        <view class="divider"></view>
        <view class="total-row">
          <text class="label">实付金额</text>
          <view class="price-box">
            <text class="symbol">¥</text>
            <text class="big-price">{{order.totalPrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部固定操作栏 -->
  <view class="footer-bar" wx:if="{{order.canRefund}}">
    <button class="btn-secondary" open-type="contact">联系客服</button>
    <button class="btn-primary" bindtap="applyRefund">申请退款</button>
  </view>
</view>
