page {
  background-color: #f5f6f8;
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  padding-bottom: 0;
}

/* Image Area */
.img-container {
  width: 100%;
  height: 520rpx;
  position: relative;
}

.product-img {
  width: 100%;
  height: 100%;
  background-color: #fff;
}

/* Common Card Styles */
.info-card, .card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 24rpx 20rpx; /* Tighter margins */
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.02);
  width: 100%;
  box-sizing: border-box;
}

/* Info Card Specifics */
.info-card {
  margin-top: -40rpx; /* Overlap image */
  position: relative;
  z-index: 10;
  padding: 40rpx;
  width: 100%;
  box-sizing: border-box;

}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price-wrapper {
  color: #ff4d4f;
  font-weight: 800;
  line-height: 1;
  margin-right: 20rpx;
}

.currency {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.price-num {
  font-size: 64rpx; /* Larger Price */
  letter-spacing: -2rpx;
}

.sales {
  font-size: 24rpx;
  color: #999;
  background-color: #f7f7f7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.header-row {
  margin-bottom: 12rpx;
}

.name {
  font-size: 40rpx; /* Larger Name */
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.desc {
  font-size: 28rpx;
  color: #888;
  line-height: 1.4;
}

/* Section Titles */
.section-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #bbb;
  margin-left: 12rpx;
}

/* Remark Area */
.remark-input {
  width: 100%;
  height: 120rpx; /* Compact height */
  background-color: #f9f9f9;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border-radius: 12rpx;
  color: #333;
}

/* Detail Area */
.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
  margin-top: 20rpx;
}

.bottom-spacer {
  height: 160rpx; /* Accommodate taller bottom bar */
}

/* Bottom Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx; /* Taller bar */
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.cart-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.cart-icon-box {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-symbol {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  border: 2rpx solid #fff;
  min-width: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

.cart-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.action-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* Stepper */
.stepper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  height: 80rpx; /* Larger stepper */
  padding: 0 4rpx;
  margin-right: 20rpx;
}

.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.stepper-btn.minus.disabled {
  color: #ccc;
}

.count {
  min-width: 60rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* Add Button */
.add-btn {
  flex: 1;
  background: linear-gradient(135deg, #ff7875, #ff4d4f);
  color: #fff;
  height: 90rpx; /* Larger button */
  line-height: 90rpx;
  text-align: center;
  border-radius: 45rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(255, 77, 79, 0.3);
  max-width: 320rpx; /* Don't get too wide on tablets */
}
